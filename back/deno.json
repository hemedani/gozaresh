{
  "name": "gozarish-backend",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-all --watch mod.ts",
    "bc-dev": "deno run --allow-all --watch mod.ts"
  },
  "fmt": {
    "include": ["src/", "models/", "utils/", "mod.ts", "deps.ts"],
    "semiColons": true,
    "singleQuote": false,
    "indentWidth": 2
  },
  "lint": {
    "include": ["src/", "models/", "utils/", "mod.ts", "deps.ts"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true
  }
}
